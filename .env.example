# Document creation API (required for POST /api/documents)
DOCUMENTS_API_KEY=your-secret-api-key

# App URL for document links. Set to https://weezmo.vercel.app in Vercel so links never use preview URLs.
NEXT_PUBLIC_APP_URL=https://weezmo.vercel.app

# Supabase (Weezmo project)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin dashboard (/admin/surveys): comma-separated emails allowed after Supabase login.
# Use * only in dev to allow any authenticated user.
ADMIN_EMAIL_ALLOWLIST=you@example.com

# Newsletter signup: POST to this URL with { actionType: "weezmo", email, phone?, fullName? }
NEWSLETTER_WEBHOOK_URL=https://hook.eu2.make.com/fbkgcg6xxftadanbotb57tm452kfyvmo

# Customer survey submit: POST JSON from /api/survey-submit to this URL (plain JSON, no auth in v1)
SURVEY_SUBMIT_WEBHOOK_URL=
